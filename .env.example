# .env – Local development environment variables
# Copy this to .env and fill in your real values.
# NEVER commit the filled-in .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings

# ── Azure Cognitive Services TTS ──────────────────────────────────────────
AZURE_TTS_KEY=your_azure_key_here
AZURE_TTS_REGION=eastus

# ── Hugging Face ──────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated – include your Vercel deploy URL and localhost for dev
ALLOWED_ORIGINS_STR=http://localhost:3000,https://adaptable.vercel.app
